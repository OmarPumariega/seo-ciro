generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Usuario de la agencia con acceso al panel. Un único usuario por ahora,
// pero el campo `role` deja preparado el terreno para multi-usuario futuro.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

// Un cliente/dominio gestionado por la agencia. Es la entidad central de la
// que cuelgan el resto de módulos (keyword research, rank tracking, auditorías...).
model Project {
  id     String  @id @default(cuid())
  name   String
  slug   String  @unique
  domain String?

  // NAP — solo relevante si el proyecto es un negocio local (Módulo 9 Geogrid
  // solo se activa cuando isLocalBusiness = true).
  isLocalBusiness Boolean @default(false)
  businessName    String?
  address         String?
  phone           String?
  hours           Json?

  // Perfil de marca, usado por el generador de contenido (Módulo 7) y de
  // títulos/metas (Módulo 3).
  toneOfVoice String?
  notes       String?

  // Módulo 6 — propiedad de Search Console / GA4 seleccionada para este
  // proyecto. String simple (no FK): son identificadores que vienen
  // directos de la API de Google, no filas locales.
  gscSiteUrl    String?
  ga4PropertyId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titleMetaGenerations TitleMetaGeneration[]
  schemaGenerations    SchemaGeneration[]
  apiUsageLogs         ApiUsageLog[]
  contentGenerations   ContentGeneration[]
}

// Módulo 3 — un registro por generación exitosa (URL por URL, sin modo
// masivo). Los scrapes fallidos o respuestas mal formadas del LLM no se
// persisten, para que el historial del proyecto solo muestre resultados
// usables.
model TitleMetaGeneration {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  keyword   String? // keyword objetivo manual — hasta que exista el Módulo 1
  variants  Json // [{ title, description }] x3
  model     String // modelo de OpenRouter usado para generar
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

// Módulo 4 — un registro por generación exitosa y validada.
model SchemaGeneration {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url              String
  suggestedType    String // heurística automática: LocalBusiness | Article | FAQPage
  selectedType     String // tipo realmente usado (= suggestedType o override manual)
  jsonLd           Json
  valid            Boolean
  validationErrors Json? // string[] — null si valid = true
  model            String? // null para LocalBusiness (mapeo determinista, sin LLM)
  createdAt        DateTime @default(now())

  @@index([projectId, createdAt])
}

// Infraestructura transversal (sección 5 del spec) — versión mínima: solo
// el registro de coste, sin topes de gasto ni alertas todavía.
model ApiUsageLog {
  id               String   @id @default(cuid())
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  api              String // "openrouter"
  endpoint         String // "modulo3.titulos-meta" | "modulo4.schema.article" | "modulo4.schema.faq"
  model            String?
  promptTokens     Int?
  completionTokens Int?
  costUsd          Decimal? @db.Decimal(10, 6)
  createdAt        DateTime @default(now())

  @@index([projectId, createdAt])
}

// Módulo 6 — conexión OAuth2 única de la agencia con Google (una cuenta
// para toda la agencia, no por proyecto). Id fijo ("singleton") en vez de
// findFirst + lógica de "borrar si existe" — reconectar es un upsert sobre
// ese id, sin hueco de condición de carrera ni ambigüedad de qué fila es
// la buena.
model GoogleConnection {
  id                    String   @id @default("singleton")
  googleEmail           String
  encryptedRefreshToken String // cifrado con src/lib/crypto.ts
  scope                 String // scopes concedidos, tal cual los devuelve Google
  connectedAt           DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Módulo 7 — un registro por generación exitosa. El historial por proyecto
// hace de "versionado" (sección 6 del spec: comparar/recuperar) — no hace
// falta un modelo padre/hijo aparte, la lista cronológica ya cumple esa
// función, igual que el historial del Módulo 3.
model ContentGeneration {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String // "blog" | "pagina" | "producto" | "novedad_gbp"
  topic     String
  keyword   String?
  targetUrl String?
  content   String // texto plano con jerarquía de encabezados en Markdown (#, ##...)
  wordCount Int
  model     String
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}
