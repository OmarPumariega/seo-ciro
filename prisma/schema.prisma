generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Usuario de la agencia con acceso al panel. Un único usuario por ahora,
// pero el campo `role` deja preparado el terreno para multi-usuario futuro.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

// Un cliente/dominio gestionado por la agencia. Es la entidad central de la
// que cuelgan el resto de módulos (keyword research, rank tracking, auditorías...).
model Project {
  id     String  @id @default(cuid())
  name   String
  slug   String  @unique
  domain String?

  // NAP — solo relevante si el proyecto es un negocio local (Módulo 9 Geogrid
  // solo se activa cuando isLocalBusiness = true).
  isLocalBusiness Boolean @default(false)
  businessName    String?
  address         String?
  phone           String?
  hours           Json?
  // Coordenadas exactas del negocio (centro del geogrid). El usuario las
  // introduce manualmente (futuro: geocodificar desde address). Sin ellas no
  // se puede ejecutar un geogrid del Módulo 9.
  lat             Float?
  lng             Float?

  // Ficha de Google Business Profile de referencia para el geogrid (Módulo 9):
  // el matching en Maps SERP prioriza place_id (exacto) y luego el nombre tal
  // cual aparece en GBP. Opcionales, pero mejoran la precisión del geogrid.
  gbpName    String?
  gbpPlaceId String?

  // Perfil de marca, usado por el generador de contenido (Módulo 7) y de
  // títulos/metas (Módulo 3).
  toneOfVoice String?
  notes       String?

  // Módulo 6 — propiedad de Search Console / GA4 seleccionada para este
  // proyecto. String simple (no FK): son identificadores que vienen
  // directos de la API de Google, no filas locales.
  gscSiteUrl    String?
  ga4PropertyId String?

  // Módulo 8 — programación automática de auditorías. "manual" = solo al
  // disparar desde la UI; "monthly" = el cron crea una AuditRun pending cuando
  // toca (cada ~30 días). auditLastRunAt marca el último disparo (manual o auto)
  // para calcular cuándo toca la siguiente.
  auditFrequency String   @default("manual") // "manual" | "monthly"
  auditLastRunAt DateTime?

  // Tope de gasto mensual de DataForSEO propio de este proyecto (USD). Opcional;
  // si está puesto, las llamadas de este proyecto se bloquean al superarlo (suma
  // de su ApiUsageLog del mes). Se suma al tope global (DATAFORSEO_MONTHLY_LIMIT_USD).
  spendLimitUsd Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titleMetaGenerations TitleMetaGeneration[]
  schemaGenerations    SchemaGeneration[]
  apiUsageLogs         ApiUsageLog[]
  contentGenerations   ContentGeneration[]
  auditRuns            AuditRun[]
  keywordStudies       KeywordStudy[]
  rankKeywords         RankKeyword[]
  geogridRuns          GeogridRun[]
  todos                TodoItem[]
  copilotThreads       CopilotThread[]
  competitors          Competitor[]
  visibilitySnapshots  VisibilitySnapshot[]
}

// Módulo 3 — un registro por generación exitosa (URL por URL, sin modo
// masivo). Los scrapes fallidos o respuestas mal formadas del LLM no se
// persisten, para que el historial del proyecto solo muestre resultados
// usables.
model TitleMetaGeneration {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  keyword   String? // keyword objetivo manual — hasta que exista el Módulo 1
  variants  Json // [{ title, description }] x3
  model     String // modelo de OpenRouter usado para generar
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

// Módulo 4 — un registro por generación exitosa y validada.
model SchemaGeneration {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url              String
  suggestedType    String // heurística automática: LocalBusiness | Article | FAQPage
  selectedType     String // tipo realmente usado (= suggestedType o override manual)
  jsonLd           Json
  valid            Boolean
  validationErrors Json? // string[] — null si valid = true
  model            String? // null para LocalBusiness (mapeo determinista, sin LLM)
  createdAt        DateTime @default(now())

  @@index([projectId, createdAt])
}

// Infraestructura transversal (sección 5 del spec) — versión mínima: solo
// el registro de coste, sin topes de gasto ni alertas todavía.
model ApiUsageLog {
  id               String   @id @default(cuid())
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  api              String // "openrouter"
  endpoint         String // "modulo3.titulos-meta" | "modulo4.schema.article" | "modulo4.schema.faq"
  model            String?
  promptTokens     Int?
  completionTokens Int?
  costUsd          Decimal? @db.Decimal(10, 6)
  createdAt        DateTime @default(now())

  @@index([projectId, createdAt])
}

// Módulo 6 — conexión OAuth2 única de la agencia con Google (una cuenta
// para toda la agencia, no por proyecto). Id fijo ("singleton") en vez de
// findFirst + lógica de "borrar si existe" — reconectar es un upsert sobre
// ese id, sin hueco de condición de carrera ni ambigüedad de qué fila es
// la buena.
model GoogleConnection {
  id                    String   @id @default("singleton")
  googleEmail           String
  encryptedRefreshToken String // cifrado con src/lib/crypto.ts
  scope                 String // scopes concedidos, tal cual los devuelve Google
  connectedAt           DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Módulo 7 — un registro por generación exitosa. El historial por proyecto
// hace de "versionado" (sección 6 del spec: comparar/recuperar) — no hace
// falta un modelo padre/hijo aparte, la lista cronológica ya cumple esa
// función, igual que el historial del Módulo 3.
model ContentGeneration {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String // "blog" | "pagina" | "producto" | "novedad_gbp"
  topic     String
  keyword   String?
  targetUrl String?
  content   String // texto plano con jerarquía de encabezados en Markdown (#, ##...)
  wordCount Int
  model     String
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

// Módulo 8 — una fila por auditoría disparada. Primer módulo con datos
// genuinamente anidados N-por-ejecución (hasta ~50 páginas), a diferencia
// de las generaciones de una sola fila de los módulos 3/4/7 — de ahí una
// tabla hija (AuditPage) en vez de un JSON dentro de esta.
model AuditRun {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status         String    @default("pending") // pending | running | completed | failed
  startUrl       String
  triggeredAt    DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  pagesCrawled   Int       @default(0)
  sitemapFound   Boolean?
  robotsBlocked  Boolean   @default(false)
  overallScore   Int? // 0-100, null si no completada o robotsBlocked
  categoryScores Json? // detalle numérico por categoría, auditable a mano
  psiData        Json? // PageSpeed Insights de la home únicamente
  gscChecked     Boolean   @default(false)
  linkGraph      Json? // grafo de enlaces internos { url, links[] } (PageRank/enlazado M interno)
  errorMessage   String?
  pages          AuditPage[]

  @@index([projectId, triggeredAt])
}

// Una fila por URL rastreada en una auditoría.
model AuditPage {
  id                String   @id @default(cuid())
  auditRunId        String
  auditRun          AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  url               String
  statusCode        Int?
  isHttps           Boolean
  isRedirect        Boolean  @default(false) // la página implicó una redirección 3xx
  canonicalUrl      String?
  metaRobots        String?
  title             String? // <title> de la página
  titleLength       Int? // caracteres del título
  metaDescription   String? // <meta name="description">
  metaLength        Int? // caracteres de la meta description
  h1Count           Int? // nº de etiquetas H1
  h1Text            String? // primer H1
  imagesTotal       Int      @default(0)
  imagesMissingAlt  Int      @default(0)
  brokenLinksCount  Int      @default(0)
  brokenLinksSample Json? // hasta 10 URLs rotas, para mostrar en UI sin tabla aparte
  wordCount         Int? // nº de palabras del cuerpo (detección de thin content)
  inSearchConsole   Boolean? // null si gscChecked=false en el AuditRun padre
  issues            Json? // ["missing_canonical", "noindex", "no_https", "title_long"...]
  createdAt         DateTime @default(now())

  @@unique([auditRunId, url])
  @@index([auditRunId])
}

// Módulo 1 — un "estudio" es una lista de keywords pegada por el usuario
// para un proyecto, con los datos de DataForSEO ya resueltos y la
// estructura de URLs/encabezados opcionalmente generada encima.
model KeywordStudy {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  languageCode   String   @default("es")
  locationCode   Int      @default(2724) // España
  structure      Json? // { pages: [{ slug, h1, headings, navLabel, keywords }] }
  structureModel String? // modelo de OpenRouter usado; null hasta que se genera
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  keywords       Keyword[]

  @@index([projectId, createdAt])
}

// Una fila por keyword dentro de un estudio.
model Keyword {
  id           String       @id @default(cuid())
  studyId      String
  study        KeywordStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  keyword      String // normalizada (minúsculas, espacios colapsados)
  searchVolume Int? // null = DataForSEO no tiene dato, nunca 0 fabricado
  competition  String? // "HIGH" | "MEDIUM" | "LOW", tal cual DataForSEO
  cpc          Decimal? @db.Decimal(10, 2)
  intent       String? // "informacional" | "mixta" | "transaccional"
  priority     Int // 0-100, cuota de volumen dentro del estudio

  @@unique([studyId, keyword])
  @@index([studyId, priority])
}

// Primera tabla de caché de la app (sección 5 del spec: "evitar pagar dos
// veces por el mismo dato"). Clave por (keyword, idioma, ubicación), no por
// proyecto/estudio — el volumen de una keyword no depende de quién la pidió.
// 30 días de frescura (ver src/lib/keywords/cache.ts) antes de volver a
// pagar por ella.
model KeywordDataCache {
  id           String   @id @default(cuid())
  keyword      String
  languageCode String
  locationCode Int
  searchVolume Int?
  competition  String?
  cpc          Decimal? @db.Decimal(10, 2)
  intent       String?
  fetchedAt    DateTime @default(now())

  @@unique([keyword, languageCode, locationCode])
}

// Módulo 5 — una keyword que se sigue posicionalmente para un proyecto
// (dominio). Desacoplada de los estudios (Módulo 1): la misma keyword en
// varios estudios se rastrea una sola vez para el dominio, porque la
// posición es un atributo del proyecto, no del estudio de investigación.
// El device (desktop/mobile) define un SERP distinto → es parte de la clave
// única (se puede seguir la misma keyword en los dos devices por separado).
model RankKeyword {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyword       String // normalizada
  locationCode  Int      @default(2724)
  languageCode  String   @default("es")
  device        String   @default("desktop") // "desktop" | "mobile"
  frequency     String   @default("weekly") // "manual" | "daily" | "weekly" | "monthly"
  depth         Int      @default(10) // resultados a parsear: 10/30/50/100 (coste ~proporcional)
  lastPosition  Int? // null = nunca comprobada, o fuera del depth pedido
  bestPosition  Int? // mejor (más baja) posición histórica
  lastCheckedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  positions     RankPosition[]

  @@unique([projectId, keyword, locationCode, languageCode, device])
  @@index([projectId])
  @@index([lastCheckedAt])
}

// Una fila por chequeo de posición (histórico para la gráfica de evolución).
// position null = el dominio no aparecía entre los resultados pedidos (depth).
model RankPosition {
  id            String      @id @default(cuid())
  rankKeywordId String
  rankKeyword   RankKeyword @relation(fields: [rankKeywordId], references: [id], onDelete: Cascade)
  checkedAt     DateTime    @default(now())
  position      Int? // null = fuera del depth pedido (no apareció)
  url           String? // URL del proyecto que posiciona, si apareció

  @@index([rankKeywordId, checkedAt])
}

// Módulo 9 — una ejecución de geogrid: rejilla N×N de puntos alrededor del
// negocio, cada uno consultando Maps SERP para ver en qué posición aparece el
// negocio para la keyword dada en ese punto. Procesada en background por el
// cron (pending → running → completed/failed), como las auditorías del Módulo 8
// — una rejilla 5×5 son 25 llamadas (~75s), demasiado largo para síncrono.
//
// Los puntos van en un JSON (no tabla hija) porque siempre se pintan juntos
// como mapa de calor, nunca se filtran individualmente (a diferencia de las
// páginas de una auditoría, que sí se listan/filtran).
model GeogridRun {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyword       String
  gridSize      Int // 3 | 5 | 7
  radiusKm      Float // distancia del centro al borde de la rejilla
  centerLat     Float
  centerLng     Float
  zoom          Int      @default(15) // zoom fijo por punto (área ~vecinal)
  status        String   @default("pending") // pending | running | completed | failed
  points        Json? // [{ row, col, lat, lng, position, title }]
  averagePosition Float? // media de posiciones (solo de los puntos donde apareció)
  foundCount    Int? // nº de puntos donde el negocio apareció (sobre gridSize²)
  errorMessage  String?
  triggeredAt   DateTime @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([projectId, triggeredAt])
}

// Módulo 2 — to-do list por proyecto. Tareas manuales que la agencia anota en
// la ficha del cliente (pendientes genéricos de SEO, no generados auto). Con
// fecha opcional (dueDate) para avisos futuros en el dashboard.
model TodoItem {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text        String
  done        Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([projectId])
}

// Registro de avisos por email ya enviados, para NO espamear (cada avise se
// manda una sola vez por clave: p.ej. una auditoría por run, una caída de
// posición por keyword y día, un aviso de tope por tipo y día). Clave
// compuesta (type, key) → upsert idempotente.
model NotificationLog {
  id     String   @id @default(cuid())
  type   String // "audit_completed" | "audit_failed" | "rank_drop" | "spend_warning" | "spend_exceeded"
  key    String // dedupe: runId, keywordId+fecha, tipo+fecha
  sentAt DateTime @default(now())

  @@unique([type, key])
  @@index([type])
}

// Conversaciones del Copilot SEO (IA que entiende los datos del proyecto).
// messages = [{role:"user"|"assistant", content}]. Un hilo por proyecto, con
// título autogenerado del primer mensaje para distinguirlos en la lista.
model CopilotThread {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, updatedAt])
}

// Cache de SERP orgánico compartida entre módulos (sección 5 del spec:
// "evitar pagar dos veces por el mismo dato"). Rank tracking (M5) y TF-IDF
// piden el mismo SERP orgánico para una keyword — el primero para sacar la
// posición, el segundo para el top-10 de URLs. Aquí se cachea el top-10
// orgánico (url, title, domain) para que el TF-IDF lo reuse gratis si la
// keyword ya se sigue. TTL 7 días (el top-10 cambia despacio). Clave por
// (keyword, idioma, ubicación, device).
model SerpCache {
  id           String   @id @default(cuid())
  keyword      String
  locationCode Int
  languageCode String
  device       String
  results      Json // [{url, title, domain}] top orgánico
  fetchedAt    DateTime @default(now())

  @@unique([keyword, locationCode, languageCode, device])
  @@index([keyword, locationCode, languageCode, device])
}

// Tier 2 — competidor de un proyecto (espionaje de visibilidad + content gap).
// El dominio propio del proyecto NO va aquí (se analiza con su `domain`); aquí
// van los dominios competidores que la agencia quiere vigilar.
model Competitor {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain       String // dominio normalizado (sin esquema/www)
  contentGap   Json? // [{keyword, volume, position}] — keywords que rankea y el proyecto no
  contentGapAt DateTime?
  createdAt    DateTime  @default(now())

  @@unique([projectId, domain])
  @@index([projectId])
}

// Snapshot de visibilidad de un dominio (el del proyecto o un competidor):
// tráfico orgánico estimado (metrics.organic.etv), nº de keywords orgánicas
// (metrics.organic.count) y top keywords. Se añade uno por análisis → con el
// tiempo acumula tendencia. El coste real se paga al ANALIZAR (explícito); ver
// los resultados es gratis (lee el snapshot más reciente).
model VisibilitySnapshot {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain          String // dominio analizado (proyecto o competidor)
  organicTraffic  Float? // metrics.organic.etv (tráfico orgánico estimado mensual)
  organicKeywords Int? // metrics.organic.count (nº de SERPs orgánicas)
  topKeywords     Json? // [{keyword, position, volume}]
  fetchedAt       DateTime @default(now())

  @@index([projectId, domain, fetchedAt])
}
