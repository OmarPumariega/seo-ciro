# ============================================================
# SEO CIRO — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# Base de datos PostgreSQL
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB"

# Usadas por docker-compose.yml para levantar el contenedor de Postgres
# (DATABASE_URL se sobrescribe automáticamente en producción para apuntar a "db")
POSTGRES_USER="seo"
POSTGRES_PASSWORD="CAMBIA_ESTO"
POSTGRES_DB="seo"

# NextAuth — genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO"
NEXTAUTH_URL="https://tudominio.com"

# Encriptación AES-256 para futuros secretos (tokens OAuth, API keys de terceros)
# Exactamente 32 caracteres — genera con: openssl rand -hex 16
ENCRYPTION_KEY="CADENA_ALEATORIA_DE_EXACTAMENTE_32__"
